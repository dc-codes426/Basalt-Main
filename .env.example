# Basalt — local dev environment variables
#
# Copy to .env and fill in values:
#   cp .env.example .env
#
# On Phala (production), these are derived from the TEE hardware key
# and do not need to be set.

# ─── Redis ───────────────────────────────────────────────────────────
REDIS_PASSWORD=              # generate: openssl rand -base64 24

# ─── MinIO / Block Storage ───────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=         # generate: openssl rand -base64 24
BLOCK_STORAGE_BUCKET=vaults

# ─── MinIO SSE (encryption at rest) ─────────────────────────────────
# 64-char hex (256-bit key). Optional for dev — if empty, SSE is disabled.
# generate: openssl rand -hex 32
MINIO_SSE_MASTER_KEY=

# ─── Relay ───────────────────────────────────────────────────────────
RELAY_SERVER=https://api.vultisig.com/router
